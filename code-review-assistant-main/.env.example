# ==============================
# Anthropic Configuration
# ==============================

# Get your API key from:
# https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use
MODEL_NAME=claude-3-5-sonnet-latest

# Enable mock mode (true/false)
USE_MOCK=false


# ==============================
# FastAPI Configuration
# ==============================

HOST=0.0.0.0
PORT=8000


# ==============================
# Logging
# ==============================

LOG_LEVEL=INFO